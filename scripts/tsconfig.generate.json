{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "../.tmp-generate",
    "rootDir": "..",
    "types": ["node"],
    "resolveJsonModule": true
  },
  "include": [
    "../scripts/**/*.ts",
    "../src/lib/**/*.ts",
    "../src/components/primitives/**/*.tsx"
  ]
}

