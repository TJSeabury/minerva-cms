---
import "../styles/global.css";

type Props = {
  title?: string;
};

const { title = "UIDD Experiment" } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <header class="border-b border-slate-200">
      <div class="mx-auto max-w-5xl px-4 py-4">
        <a href="/" class="font-semibold text-slate-900">UIDD</a>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-4 py-10">
      <slot />
    </main>
  </body>
</html>

