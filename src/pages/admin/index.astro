---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { listPageSlugs } from "../../lib/content";

const slugs = await listPageSlugs();
---

<BaseLayout title="Admin">
  <section class="min-h-[60vh]">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-2xl font-semibold">Admin</h1>
      <p class="mt-2 text-slate-700">
        Choose a page to edit. The form is generated from your templates.
      </p>

      <div
        class="mt-6 space-y-2 rounded-lg border border-slate-200 bg-white p-4"
      >
        {
          slugs.length === 0 ? (
            <div class="text-sm text-slate-600">No editable pages found.</div>
          ) : (
            slugs.map((slug) => (
              <a
                href={`/admin/${slug}`}
                class="flex items-center justify-between rounded-md border border-slate-200 px-3 py-2 hover:bg-slate-50"
              >
                <span class="text-sm font-medium text-slate-900">{slug}</span>
                <span class="text-sm text-slate-500">Edit</span>
              </a>
            ))
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>
